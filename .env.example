# SAMKWANG AI 워크스페이스 루트에 .env 로 복사하여 사용

# CORS: 브라우저에서 API 호출이 막히면 프론트 주소를 콤마로 나열 (예: http://192.168.5.176:8080)
# "*" 는 개발 편의용(쿠키 인증은 프론트·백 도메인 맞추기 어려울 수 있음)
CORS_ORIGINS=*

# OpenAI
OPENAI_API_KEY=
DEFAULT_CHAT_MODEL=gpt-4o-mini
CHAT_TOOLS_MODEL=gpt-4o-mini

# DB
# SQLite(개발) 또는 PostgreSQL. 회원가입 데이터는 `login` 테이블에 저장됩니다.
# 예: postgresql+psycopg2://user:password@127.0.0.1:5432/samkwang
DATABASE_URL=sqlite:///./samkwang.db

# RAG (비우면 워크스페이스 `document` 폴더 사용)
DOCUMENTS_PATH=
VECTOR_DB_PATH=

# JWT / 관리자
JWT_SECRET=
ADMIN_USERNAMES=admin

# ERP REST (비어 있으면 데모 목 데이터)
ERP_BASE_URL=
ERP_AUTH_MODE=none
ERP_API_KEY=
ERP_API_KEY_HEADER=X-API-Key
ERP_TIMEOUT_SECONDS=30
ERP_TOOLS_ENABLED=true

# MCP stdio (백엔드가 자식 프로세스로 기동)
# MCP_CWD: 반드시 mcp_server 폴더가 있는 워크스페이스 루트(예: .../SAMKWANG AI). 비우면 자동.
# 잘못된 경로(예: backend만 지정)면 자동으로 루트로 보정됩니다.
# MCP_PYTHON: 비우면 현재 uvicorn과 동일한 python(백엔드 venv 권장). mcp 미설치 시 여기에 .venv/bin/python 지정.
MCP_PYTHON=
MCP_MODULE=mcp_server.mcp_erp_server
MCP_CWD=
